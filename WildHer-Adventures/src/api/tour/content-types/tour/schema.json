{
  "kind": "collectionType",
  "collectionName": "tours",
  "info": {
    "singularName": "tour",
    "pluralName": "tours",
    "displayName": "Tour",
    "description": "Ture i iskustva — jednodnevne, vikend, ekspedicije, retreat"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shortDescription": {
      "type": "text",
      "maxLength": 300
    },
    "description": {
      "type": "richtext"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "duration": {
      "type": "string",
      "description": "npr. 1 dan, 2 dana, 5 dana"
    },
    "difficulty": {
      "type": "enumeration",
      "enum": ["easy", "moderate", "challenging", "demanding", "expert"],
      "description": "lagano → expert (1–5)"
    },
    "lengthKm": {
      "type": "float"
    },
    "elevationM": {
      "type": "integer"
    },
    "maxGroupSize": {
      "type": "integer"
    },
    "minAge": {
      "type": "integer"
    },
    "price": {
      "type": "decimal"
    },
    "currency": {
      "type": "string",
      "default": "EUR"
    },
    "itinerary": {
      "type": "richtext"
    },
    "included": {
      "type": "richtext",
      "description": "Šta je uključeno u cijenu"
    },
    "excluded": {
      "type": "richtext"
    },
    "whatToBring": {
      "type": "richtext"
    },
    "physicalPreparation": {
      "type": "richtext",
      "description": "Je li ova tura za mene, priprema"
    },
    "category": {
      "type": "enumeration",
      "enum": ["one-day", "weekend", "expedition", "retreat"],
      "description": "jednodnevne, vikend, ekspedicije, retreat"
    },
    "location": {
      "type": "string",
      "description": "Planina/lokacija npr. Prenj, Maglić"
    },
    "destination": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::destination.destination",
      "inversedBy": "tours",
      "description": "Povezana destinacija (opciono)"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "availableDates": {
      "type": "json",
      "description": "Lista dostupnih datuma ili JSON"
    }
  }
}
